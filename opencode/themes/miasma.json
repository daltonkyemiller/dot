{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#222222",
    "bgDark": "#1c1c1c",
    "bgDarker": "#111111",
    "bgLight": "#333333",
    "fg": "#d7c483",
    "fgDark": "#c2c2b0",
    "comment": "#666666",
    "selection": "#333333",
    "visual": "#78824b",
    "red": "#b36d43",
    "orange": "#bb7744",
    "yellow": "#c9a554",
    "green": "#5f875f",
    "olive": "#78824b",
    "brown": "#685742",
    "lightBg": "#f4f1e8",
    "lightText": "#3d3828"
  },
  "theme": {
    "primary": { "dark": "red", "light": "red" },
    "secondary": { "dark": "olive", "light": "olive" },
    "accent": { "dark": "yellow", "light": "yellow" },
    "error": { "dark": "red", "light": "red" },
    "warning": { "dark": "orange", "light": "orange" },
    "success": { "dark": "green", "light": "green" },
    "info": { "dark": "olive", "light": "olive" },
    "text": { "dark": "fg", "light": "lightText" },
    "textMuted": { "dark": "comment", "light": "comment" },
    "background": { "dark": "bg", "light": "lightBg" },
    "backgroundPanel": { "dark": "bgDark", "light": "#e8e5dc" },
    "backgroundElement": { "dark": "bgDarker", "light": "#d9d6ce" },
    "border": { "dark": "bgLight", "light": "#ccc8bf" },
    "borderActive": { "dark": "yellow", "light": "yellow" },
    "borderSubtle": { "dark": "selection", "light": "#e0ddd6" },
    "diffAdded": { "dark": "green", "light": "green" },
    "diffRemoved": { "dark": "red", "light": "red" },
    "diffContext": { "dark": "comment", "light": "comment" },
    "diffHunkHeader": { "dark": "brown", "light": "brown" },
    "diffHighlightAdded": { "dark": "#7aa87a", "light": "#4a7a4a" },
    "diffHighlightRemoved": { "dark": "#c95a3a", "light": "#9a4a2a" },
    "diffAddedBg": { "dark": "#2a3a2a", "light": "#e8f0e8" },
    "diffRemovedBg": { "dark": "#3a2a22", "light": "#f0e8e4" },
    "diffContextBg": { "dark": "bgDark", "light": "#f4f1e8" },
    "diffLineNumber": { "dark": "bgLight", "light": "#b8b5ac" },
    "diffAddedLineNumberBg": { "dark": "#253025", "light": "#dde8dd" },
    "diffRemovedLineNumberBg": { "dark": "#302520", "light": "#e8ddd8" },
    "markdownText": { "dark": "fg", "light": "lightText" },
    "markdownHeading": { "dark": "yellow", "light": "yellow" },
    "markdownLink": { "dark": "orange", "light": "orange" },
    "markdownLinkText": { "dark": "green", "light": "green" },
    "markdownCode": { "dark": "olive", "light": "olive" },
    "markdownBlockQuote": { "dark": "comment", "light": "comment" },
    "markdownEmph": { "dark": "fgDark", "light": "lightText" },
    "markdownStrong": { "dark": "red", "light": "red" },
    "markdownHorizontalRule": { "dark": "comment", "light": "comment" },
    "markdownListItem": { "dark": "orange", "light": "orange" },
    "markdownListEnumeration": { "dark": "green", "light": "green" },
    "markdownImage": { "dark": "brown", "light": "brown" },
    "markdownImageText": { "dark": "yellow", "light": "yellow" },
    "markdownCodeBlock": { "dark": "fg", "light": "lightText" },
    "syntaxComment": { "dark": "comment", "light": "comment" },
    "syntaxKeyword": { "dark": "red", "light": "red" },
    "syntaxFunction": { "dark": "yellow", "light": "yellow" },
    "syntaxVariable": { "dark": "fg", "light": "lightText" },
    "syntaxString": { "dark": "green", "light": "green" },
    "syntaxNumber": { "dark": "orange", "light": "orange" },
    "syntaxType": { "dark": "olive", "light": "olive" },
    "syntaxOperator": { "dark": "brown", "light": "brown" },
    "syntaxPunctuation": { "dark": "fgDark", "light": "lightText" }
  }
}
