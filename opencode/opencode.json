{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "typescript": {
      "disabled": true
    },
    "tsgo": {
      "command": [
        "bunx",
        "-y",
        "@typescript-language-server/tsgo",
        "--lsp",
        "-stdio"
      ],
      "extensions": [".ts", ".tsx"]
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["bunx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {
        "clientId": "{env:OPENCODE_FIGMA_CLIENT_ID}",
        "clientSecret": "{env:OPENCODE_FIGMA_CLIENT_SECRET}"
      }
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    }
  },
  "permission": "allow"
}
