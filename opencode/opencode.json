{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "/home/dalton/.agents/instructions/always.md"
  ],
  "lsp": {
    "typescript": {
      "disabled": true
    },
    "tsgo": {
      "command": [
        "bunx",
        "-y",
        "@typescript-language-server/tsgo",
        "--lsp",
        "-stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx"
      ]
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {
        "clientId": "{env:OPENCODE_FIGMA_CLIENT_ID}",
        "clientSecret": "{env:OPENCODE_FIGMA_CLIENT_SECRET}"
      }
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "uidotsh": {
      "type": "remote",
      "url": "https://ui.sh/mcp?agent=opencode",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:UIDOTSH_TOKEN}"
      }
    },
    "Neon": {
      "type": "remote",
      "url": "https://mcp.neon.tech/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:NEON_API_KEY}"
      }
    }
  },
  "permission": "allow"
}
